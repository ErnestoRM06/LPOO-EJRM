<AnchorPane id="AnchorPane" prefHeight="473.0" prefWidth="606.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pia.Vista.FXMLEquipoController">
    <stylesheets>
        <URL value="@fxml.css" />
    </stylesheets>
   <children>
