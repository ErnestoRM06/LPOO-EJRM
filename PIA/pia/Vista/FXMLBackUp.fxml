<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>

<AnchorPane id="AnchorPane" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pia.Vista.FXMLBackUpController">
    <stylesheets>
        <URL value="@fxml.css" />
    </stylesheets>
   <children>
      <HBox layoutX="24.0" layoutY="60.0" prefHeight="30.0" prefWidth="552.0">
         <children>
            <Label prefHeight="30.0" prefWidth="142.0" text="Nombre del backup:" />
            <TextField fx:id="textoRuta" prefHeight="30.0" prefWidth="381.0" />
            <Label prefHeight="30.0" prefWidth="43.0" text=".dat" />
         </children>
      </HBox>
      <Button fx:id="botonRegresar" layoutX="486.0" layoutY="307.0" mnemonicParsing="false" onAction="#regresar" text="Regresar" />
      <Button fx:id="botonCrear" layoutX="61.0" layoutY="307.0" mnemonicParsing="false" onAction="#crear" text="Crear backup" />
      <Button fx:id="botonCargar" layoutX="253.0" layoutY="307.0" mnemonicParsing="false" onAction="#cargar" text="Cargar backup" />
   </children>
</AnchorPane>
